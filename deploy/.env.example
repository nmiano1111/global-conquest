# Copy this to .env and fill in real values.
# .env is never committed to git.

# A strong random password for the Postgres container.
# Generate one with: openssl rand -base64 32
DB_PASSWORD=changeme

# Full ECR image URI — CI/CD overrides this on each deploy.
# Set it manually for the first boot, e.g.:
#   294342039804.dkr.ecr.us-east-1.amazonaws.com/global-conquest-backend:latest
ECR_IMAGE=294342039804.dkr.ecr.us-east-1.amazonaws.com/global-conquest-backend:latest

# Origin the backend allows for CORS (your S3 frontend URL).
CORS_ALLOWED_ORIGIN=http://global-conquest-frontend-294342039804.s3-website-us-east-1.amazonaws.com

# Discord bot credentials — never commit real values.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_EVENTS_CHANNEL_ID=

# Frontend URL the Discord bot links to from game names in notifications.
# Optional — if unset, notifications show the game name as plain text instead of a link.
FRONTEND_BASE_URL=http://global-conquest-frontend-294342039804.s3-website-us-east-1.amazonaws.com

# Trello credentials for the /bug and /feature Discord commands.
# A single API key + token pair (from trello.com/power-ups/admin, or
# https://trello.com/1/authorize for a personal token) — not per-user OAuth.
# All five are required; the bot fails to start without them.
TRELLO_API_KEY=
TRELLO_TOKEN=
# The Trello list new bug/feature cards get created in (triage/inbox list).
TRELLO_TRIAGE_LIST_ID=
# Label IDs applied based on which command was used.
TRELLO_BUG_LABEL_ID=
TRELLO_FEATURE_LABEL_ID=
