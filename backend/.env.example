# Copy to .env and adjust for your local setup. All values shown are the defaults.

DB_HOST=localhost
DB_PORT=5432
DB_USER=globalconq
DB_PASSWORD=globalconq
DB_NAME=globalconq
DB_SSL_MODE=disable

DISCORD_BOT_TOKEN=token
DISCORD_APPLICATION_ID=id
DISCORD_GUILD_ID=1521628387708506344
DISCORD_EVENTS_CHANNEL_ID=1521628388182196335

# Skip automatic migrations on startup
# SKIP_MIGRATIONS=true

# CORS / WebSocket origin restrictions (unset = allow all in dev)
# CORS_ALLOWED_ORIGIN=http://localhost:5173
# WS_ALLOWED_ORIGINS=http://localhost:5173
